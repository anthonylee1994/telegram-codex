#!/bin/sh

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
PROJECT_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
APP_JAR=${APP_JAR:-$PROJECT_ROOT/build/libs/telegram-codex-1.0.0.jar}
GRADLEW=${GRADLEW:-$PROJECT_ROOT/gradlew}
JAVA_NATIVE_ACCESS_OPTS=${JAVA_NATIVE_ACCESS_OPTS:---enable-native-access=ALL-UNNAMED}

if [ ! -f "$APP_JAR" ]; then
  if [ ! -x "$GRADLEW" ]; then
    echo "App jar not found at $APP_JAR, and Gradle runner not found at $GRADLEW." >&2
    exit 1
  fi

  echo "App jar not found at $APP_JAR. Running ./gradlew bootJar..." >&2
  (
    cd "$PROJECT_ROOT"
    "$GRADLEW" bootJar
  )
fi

if [ $# -gt 0 ] && [ "${1#--}" = "$1" ]; then
  TASK=$1
  shift
  exec java $JAVA_NATIVE_ACCESS_OPTS -jar "$APP_JAR" --spring.main.web-application-type=none --app.task="$TASK" "$@"
fi

exec java $JAVA_NATIVE_ACCESS_OPTS -jar "$APP_JAR" "$@"
