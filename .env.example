# HTTP server port
PORT=3000

# Public base URL used to register Telegram webhook. Do not include /telegram/webhook
BASE_URL=https://your-domain.example.com

# Telegram bot credentials
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_WEBHOOK_SECRET=replace-me

# Optional. Comma-separated Telegram user ids. Leave empty to allow everyone.
ALLOWED_TELEGRAM_USER_IDS=

# Local SQLite path
SQLITE_DB_PATH=./data/app.db

# codex exec timeout in seconds
CODEX_EXEC_TIMEOUT_SECONDS=300

# Maximum number of images accepted in one Telegram album before asking user to narrow focus
MAX_MEDIA_GROUP_IMAGES=6

# Maximum number of PDF pages to rasterize for analysis
MAX_PDF_PAGES=4

# Session / rate limit tuning
SESSION_TTL_DAYS=7
MEDIA_GROUP_WAIT_MS=1200
RATE_LIMIT_WINDOW_MS=10000
RATE_LIMIT_MAX_MESSAGES=5
