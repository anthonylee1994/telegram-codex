module Documents
end

class Documents::PdfPageRasterizer
  DEFAULT_MAX_PAGES: Integer

  class RasterizationError < StandardError
  end

  class MissingDependencyError < Documents::PdfPageRasterizer::RasterizationError
  end

  def initialize: (?max_pages: Integer) -> void
  def rasterize: (String pdf_path) -> Array[String]

  private

  attr_reader max_pages: Integer

  def pdftoppm_available?: () -> untyped
end

class Documents::TextDocumentExtractor
  DEFAULT_MAX_BYTES: Integer
  DEFAULT_MAX_CHARS: Integer

  class ExtractionResult
    attr_accessor content: String
    attr_accessor truncated: bool

    def initialize: (content: String, truncated: bool) -> void
  end

  class MissingDependencyError < StandardError
  end

  def initialize: (?max_bytes: Integer, ?max_chars: Integer) -> void
  def extract: (String file_path) -> Documents::TextDocumentExtractor::ExtractionResult

  private

  attr_reader max_bytes: Integer
  attr_reader max_chars: Integer

  def extract_raw_content: (String file_path) -> untyped
  def extract_docx_content: (String file_path) -> String
  def extract_xlsx_content: (String file_path) -> String
  def load_xlsx_shared_strings: (String file_path) -> Array[String]
  def extract_xlsx_sheet: (String file_path, String worksheet_entry, Array[String] shared_strings) -> String
  def extract_xlsx_cell_value: (Nokogiri::XML::Node cell, Array[String] shared_strings) -> String
  def unzip_list: (String file_path) -> Array[String]
  def unzip_file_content: (String file_path, String entry_path) -> String
  def ensure_unzip_available!: () -> untyped
end
