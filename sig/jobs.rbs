class ApplicationJob < ActiveJob::Base
end

class ReplyGenerationJob < ApplicationJob
  TIMEOUT_ERROR_MESSAGE: String

  def perform: (Hash[String, untyped] message_payload) -> void
  def handle_retry_exhausted: (StandardError error) -> void

  private

  def build_processed_update_flow: () -> Conversation::ProcessedUpdateFlow
  def conversation_service: () -> Conversation::Service
  def reply_generation_flow: () -> Conversation::ReplyGenerationFlow
  def telegram_client: () -> Telegram::Client
  def error_message_for: (StandardError error) -> String
end

class SessionSummaryJob < ApplicationJob
  TIMEOUT_ERROR_MESSAGE: String

  def perform: (String chat_id) -> void
  def handle_retry_exhausted: (StandardError error) -> void

  private

  def conversation_service: () -> Conversation::Service
  def telegram_client: () -> Telegram::Client
  def build_message: (summarize_result result) -> String
  def error_message_for: (StandardError error) -> String
end

class MediaGroupFlushJob < ApplicationJob
  def perform: (String key, Integer expected_deadline_at) -> void

  private

  def media_group_store: () -> Telegram::MediaGroupStore
end
