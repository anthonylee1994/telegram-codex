class Conversation::Webhooks::Action::GenerateReply < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
end

class Conversation::Webhooks::ActionExecutor
  def initialize: (
    conversation_service: Conversation::Service,
    telegram_client: Telegram::Client,
    processed_update_flow: Conversation::ProcessedUpdateFlow,
    reply_generation_job_class: singleton(ReplyGenerationJob),
    session_summary_job_class: singleton(SessionSummaryJob),
    generic_error_message: String,
    unauthorized_message: String,
    rate_limit_message: String,
    unsupported_message: String
  ) -> void
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
end

class Conversation::Webhooks::Decision
  START_COMMAND_PATTERN: Regexp
  HELP_COMMAND_PATTERN: Regexp
  NEW_SESSION_COMMAND_PATTERN: Regexp
  FORGET_COMMAND_PATTERN: Regexp
  MEMORY_COMMAND_PATTERN: Regexp
  SESSION_COMMAND_PATTERN: Regexp
  STATUS_COMMAND_PATTERN: Regexp
  SUMMARY_COMMAND_PATTERN: Regexp

  attr_reader action: Conversation::Webhooks::decision_action
  attr_reader message: Telegram::InboundMessage?
  attr_reader processed_update: ProcessedUpdate?
  attr_reader response_text: String?

  def initialize: (
    action: Conversation::Webhooks::decision_action,
    ?message: Telegram::InboundMessage?,
    ?processed_update: ProcessedUpdate?,
    ?response_text: String?
  ) -> void

  def self.unsupported: () -> Conversation::Webhooks::Decision
  def self.duplicate: (Telegram::InboundMessage message) -> Conversation::Webhooks::Decision
  def self.replay: (Telegram::InboundMessage message, ProcessedUpdate processed_update) -> Conversation::Webhooks::Decision
  def self.reject_unauthorized: (Telegram::InboundMessage message) -> Conversation::Webhooks::Decision
  def self.reset_session: (Telegram::InboundMessage message, String response_text) -> Conversation::Webhooks::Decision
  def self.show_help: (Telegram::InboundMessage message) -> Conversation::Webhooks::Decision
  def self.show_status: (Telegram::InboundMessage message) -> Conversation::Webhooks::Decision
  def self.show_session: (Telegram::InboundMessage message) -> Conversation::Webhooks::Decision
  def self.show_memory: (Telegram::InboundMessage message) -> Conversation::Webhooks::Decision
  def self.reset_memory: (Telegram::InboundMessage message, String response_text) -> Conversation::Webhooks::Decision
  def self.summarize_session: (Telegram::InboundMessage message, String response_text) -> Conversation::Webhooks::Decision
  def self.rate_limited: (Telegram::InboundMessage message) -> Conversation::Webhooks::Decision
  def self.too_many_images: (Telegram::InboundMessage message, String response_text) -> Conversation::Webhooks::Decision
  def self.generate_reply: (Telegram::InboundMessage message) -> Conversation::Webhooks::Decision

  def unsupported?: () -> bool
  def duplicate?: () -> bool
  def replay?: () -> bool
  def reject_unauthorized?: () -> bool
  def reset_session?: () -> bool
  def rate_limited?: () -> bool
  def show_help?: () -> bool
  def show_status?: () -> bool
  def show_session?: () -> bool
  def show_memory?: () -> bool
  def reset_memory?: () -> bool
  def summarize_session?: () -> bool
  def too_many_images?: () -> bool
end

class Conversation::Webhooks::Decision::Resolver
  def initialize: (
    processed_update_flow: Conversation::ProcessedUpdateFlow,
    rate_limiter: Conversation::ChatRateLimiter,
    config: AppConfig::Config,
    reset_memory_message: String,
    start_message: String,
    new_session_message: String,
    too_many_images_message: String,
    summary_queued_message: String
  ) -> void
  def call: (Telegram::InboundMessage? message) -> Conversation::Webhooks::Decision

  private

  def unsupported_message?: (Telegram::InboundMessage? message) -> bool
  def unauthorized_user?: (String user_id) -> bool
  def new_session_command?: (String text) -> bool
  def help_command?: (String text) -> bool
  def status_command?: (String text) -> bool
  def session_command?: (String text) -> bool
  def memory_command?: (String text) -> bool
  def forget_command?: (String text) -> bool
  def summary_command?: (String text) -> bool
  def start_command?: (String text) -> bool
  def too_many_media_group_images?: (Telegram::InboundMessage message) -> bool
end
