module Conversation::Webhooks
end

class Conversation::Webhooks::Action
  def initialize: (
    conversation_service: Conversation::Service,
    telegram_client: Telegram::Client,
    processed_update_flow: Conversation::ProcessedUpdateFlow,
    reply_generation_job_class: singleton(ReplyGenerationJob),
    generic_error_message: String,
    unauthorized_message: String,
    rate_limit_message: String,
    unsupported_message: String
  ) -> void
end

class Conversation::Webhooks::Action::Unsupported < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
end

class Conversation::Webhooks::Action::Duplicate < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
end

class Conversation::Webhooks::Action::Replay < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
end

class Conversation::Webhooks::Action::RejectUnauthorized < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
end

class Conversation::Webhooks::Action::ResetSession < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
end

class Conversation::Webhooks::Action::ResetMemory < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
end

class Conversation::Webhooks::Action::ShowHelp < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
end

class Conversation::Webhooks::Action::ShowStatus < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void

  private

  def build_status_message: (String chat_id) -> String
  def queue_adapter_label: () -> String
end

class Conversation::Webhooks::Action::ShowSession < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void

  private

  def build_session_message: (String chat_id) -> String
end

class Conversation::Webhooks::Action::ShowMemory < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void

  private

  def build_memory_message: (String chat_id) -> String
