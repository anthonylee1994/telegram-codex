class Conversation::Webhooks::Action::SummarizeSession < Conversation::Webhooks::Action
  def initialize: (session_summary_job_class: singleton(SessionSummaryJob), **untyped) -> void
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
end

class Conversation::Webhooks::Action::RateLimited < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
end

class Conversation::Webhooks::Action::TooManyImages < Conversation::Webhooks::Action
  def call: (Conversation::Webhooks::Decision decision, ?update: Hash[String, untyped]?) -> void
