type conversation_state = String
type processing_update = { update_id: Integer, message_id: Integer }
type reply_result = { conversation_state: String, suggested_replies: Array[String], text: String }
type memory_snapshot = { active: false } | { active: true, memory_text: String, last_updated_at: Time }
type session_snapshot = { active: false } | { active: true, last_updated_at: Time, message_count: Integer, turn_count: Integer }
type summarize_result = { status: :missing_session } | { status: :too_short, message_count: Integer } | { status: :ok, original_message_count: Integer, summary_text: String }
type telegram_command = { command: String, description: String }

module Conversation
  module Webhooks
    type decision_action =
      :unsupported |
      :duplicate |
      :replay |
      :reject_unauthorized |
      :reset_session |
      :show_help |
      :show_status |
      :show_session |
      :show_memory |
      :reset_memory |
      :summarize_session |
      :rate_limited |
      :too_many_images |
      :generate_reply
  end
end
