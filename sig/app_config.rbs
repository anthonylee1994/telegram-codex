class AppConfig
  class Config
    attr_reader allowed_telegram_user_ids: Array[String]
    attr_reader base_url: String
    attr_reader codex_exec_timeout_seconds: Integer
    attr_reader max_media_group_images: Integer
    attr_reader max_pdf_pages: Integer
    attr_reader media_group_wait_ms: Integer
    attr_reader port: Integer
    attr_reader rate_limit_max_messages: Integer
    attr_reader rate_limit_window_ms: Integer
    attr_reader session_ttl_days: Integer
    attr_reader sqlite_db_path: String
    attr_reader telegram_bot_token: String
    attr_reader telegram_webhook_secret: String

    def initialize: (
      allowed_telegram_user_ids: Array[String],
      base_url: String,
      codex_exec_timeout_seconds: Integer,
      max_media_group_images: Integer,
      max_pdf_pages: Integer,
      media_group_wait_ms: Integer,
      port: Integer,
      rate_limit_max_messages: Integer,
      rate_limit_window_ms: Integer,
      session_ttl_days: Integer,
      sqlite_db_path: String,
      telegram_bot_token: String,
      telegram_webhook_secret: String
    ) -> void
  end

  def self.fetch: () -> Config
  def self.reset!: () -> nil
end
