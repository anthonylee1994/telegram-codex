{
    "name": "telegram-codex",
    "version": "1.0.0",
    "private": true,
    "type": "commonjs",
    "scripts": {
        "build": "nest build",
        "dev": "nest start --watch",
        "start": "nest start",
        "start:prod": "node dist/main.js",
        "task": "ts-node -r tsconfig-paths/register src/task.ts",
        "test": "jest --runInBand",
        "typecheck": "tsc --noEmit",
        "prettier": "prettier --check \"src/**/*.ts\" \"*.{json,ts,js,md}\"",
        "prettier:check": "prettier --check \"src/**/*.ts\" \"*.{json,ts,js,md}\"",
        "prettier:write": "prettier --write \"src/**/*.ts\" \"*.{json,ts,js,md}\""
    },
    "dependencies": {
        "@nestjs/common": "^10.4.19",
        "@nestjs/config": "^3.3.0",
        "@nestjs/core": "^10.4.19",
        "@nestjs/platform-express": "^10.4.19",
        "@nestjs/typeorm": "^10.0.2",
        "nest-commander": "^3.17.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "sqlite3": "^5.1.7",
        "typeorm": "^0.3.28"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.4.9",
        "@nestjs/testing": "^10.4.19",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.10.1",
        "jest": "^30.2.0",
        "prettier": "^3.7.3",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3"
    }
}
